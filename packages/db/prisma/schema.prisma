// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum UploadSessionStatus {
  READY_FOR_UPLOAD
  UPLOADING
  COMPLETED
  FAILED
}

model Video {
  videoId String @id @default(uuid())

  videoChannel String

  title       String
  description String

  status     VideoStatus     @default(UPLOADING)


  // Stored once processing completes (in seconds).
  durationSeconds Int
  createdAt DateTime @default(now())

  uploadSessions UploadSession[]

  @@index([videoChannel, createdAt])
}



model UploadSession {
  id String @id @default(uuid())

  videoId String
  video   Video  @relation(fields: [videoId], references: [videoId], onDelete: Cascade)

  status UploadSessionStatus @default(READY_FOR_UPLOAD)

  originalFilename String
  contentType      String
  sizeBytes        BigInt

  // S3 placement + client checks (filled during completion).
  s3Key String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId, createdAt])
}
